<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= text.newsletter_title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&family=Inter:wght@400;500&display=swap" rel="stylesheet">
    <style>
        /* Cinema Dispatch — see builder/DESIGN.md. Email clients ignore most of
           this <style> block, so every load-bearing rule is also inlined. */
        body { margin: 0; padding: 0; }
        .serif { font-family: 'Cormorant Garamond', 'Tiempos Headline', Georgia, 'Times New Roman', serif; }
        .sans { font-family: Inter, -apple-system, 'Segoe UI', Helvetica, Arial, sans-serif; }
        a { color: #b5432c; }
    </style>
</head>
<body style="margin:0; padding:0; background-color:#f5f0e8;">

    <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#f5f0e8;">
        <tr><td align="center" style="padding: 24px 12px;">

            <table width="600" cellpadding="0" cellspacing="0" align="center"
                   style="max-width:600px; width:100%; background-color:#faf9f5; border:1px solid #e6dfd8; border-radius:16px; overflow:hidden;">

                <!-- ===== MASTHEAD (cream) ===== -->
                <tr>
                    <td align="center" style="padding: 40px 32px 8px 32px;">
                        <div style="font-family: Inter, -apple-system, 'Segoe UI', Helvetica, Arial, sans-serif; font-size:12px; font-weight:500; letter-spacing:1.5px; text-transform:uppercase; color:#6c6a64;">
                            &#10035;&nbsp;&nbsp;Cette semaine au cin&eacute;ma
                        </div>
                        <h1 style="margin: 12px 0 0 0; font-family:'Cormorant Garamond','Tiempos Headline',Georgia,'Times New Roman',serif; font-size:44px; font-weight:500; line-height:1.05; letter-spacing:-1px; color:#141413;">
                            <%= text.newsletter_title %>
                        </h1>
                        <table cellpadding="0" cellspacing="0" align="center" style="margin: 18px auto 0 auto;">
                            <tr><td width="56" height="2" style="background-color:#c8a24a; font-size:0; line-height:0;">&nbsp;</td></tr>
                        </table>
                    </td>
                </tr>
                <% if (text.global_intro) { %>
                <tr>
                    <td align="center" style="padding: 16px 48px 36px 48px;">
                        <p style="margin:0; font-family: Inter, -apple-system, 'Segoe UI', Helvetica, Arial, sans-serif; font-size:16px; line-height:1.55; color:#3d3d3a;">
                            <%= text.global_intro %>
                        </p>
                    </td>
                </tr>
                <% } %>

                <!-- ===== SECTIONS ===== -->
                <% const sectionKeys = Object.keys(sections); %>
                <% sectionKeys.forEach((sectionKey, sIdx) => { %>
                    <% const config = sectionsConfig[sectionKey] || { title: sectionKey, description: "" }; %>
                    <% const numeral = String(sIdx + 1).padStart(2, '0'); %>

                    <!-- Section header -->
                    <tr>
                        <td style="padding: <%= sIdx === 0 ? '8px' : '40px' %> 32px 0 32px;">
                            <table width="100%" cellpadding="0" cellspacing="0">
                                <tr>
                                    <td style="border-top:1px solid #e6dfd8; padding-top: 24px;">
                                        <div style="font-family: Inter, -apple-system, 'Segoe UI', Helvetica, Arial, sans-serif; font-size:12px; font-weight:500; letter-spacing:1.5px; text-transform:uppercase; color:#c8a24a;">
                                            N&deg;&nbsp;<%= numeral %>
                                        </div>
                                        <h2 style="margin: 6px 0 0 0; font-family:'Cormorant Garamond','Tiempos Headline',Georgia,'Times New Roman',serif; font-size:30px; font-weight:500; line-height:1.15; letter-spacing:-0.5px; color:#141413;">
                                            <%= config.title %>
                                        </h2>
                                        <% if (config.description) { %>
                                        <p style="margin: 6px 0 0 0; font-family: Inter, -apple-system, 'Segoe UI', Helvetica, Arial, sans-serif; font-size:14px; line-height:1.55; color:#6c6a64; font-style:italic;">
                                            <%= config.description %>
                                        </p>
                                        <% } %>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <!-- Movies -->
                    <% sections[sectionKey].forEach((movie, mIdx) => { %>
                    <% const isMarquee = sIdx === 0 && mIdx === 0; %>
                    <% if (isMarquee) { %>
                    <!-- ===== MARQUEE FEATURE (espresso panel) ===== -->
                    <tr>
                        <td style="padding: 24px 24px 8px 24px;">
                            <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#161210; border-radius:12px;">
                                <tr><td style="padding: 28px;">
                                    <div style="margin-bottom: 14px;">
                                        <span style="display:inline-block; background-color:#c8a24a; color:#141413; font-family: Inter, -apple-system, 'Segoe UI', Helvetica, Arial, sans-serif; font-size:11px; font-weight:500; letter-spacing:1.5px; text-transform:uppercase; padding: 4px 12px; border-radius:9999px;">
                                            &Agrave; la une
                                        </span>
                                    </div>
                                    <table width="100%" cellpadding="0" cellspacing="0">
                                        <tr>
                                            <td width="130" valign="top">
                                                <img src="<%= movie.poster_url %>" width="120" alt="<%= movie.title %>" style="display:block; border-radius:8px;">
                                            </td>
                                            <td valign="top" style="padding-left: 18px;">
                                                <h3 style="margin:0 0 6px 0; font-family:'Cormorant Garamond','Tiempos Headline',Georgia,'Times New Roman',serif; font-size:28px; font-weight:500; line-height:1.15; letter-spacing:-0.3px; color:#faf9f5;">
                                                    <%= movie.title %>
                                                </h3>
                                                <div style="font-family: Inter, -apple-system, 'Segoe UI', Helvetica, Arial, sans-serif; font-size:13px; line-height:1.5; color:#9c9086;">
                                                    <%= movie.year %><% if (movie.duration_minutes) { %> &middot; <%= movie.duration_minutes %> min<% } %><% if (movie.genre) { %> &middot; <%= movie.genre %><% } %>
                                                    <br>De <%= movie.director %>
                                                </div>
                                                <% if (movie.ui_ratings.length > 0) { %>
                                                <div style="margin-top: 12px;">
                                                    <% movie.ui_ratings.forEach(rating => { %>
                                                        <span style="display:inline-block; margin: 0 10px 6px 0; font-family: Inter, -apple-system, 'Segoe UI', Helvetica, Arial, sans-serif; font-size:12px; font-weight:500; color:#faf9f5;">
                                                            <img src="<%= rating.logo_url %>" height="14" alt="<%= rating.source %>" style="vertical-align:middle; height:14px; width:auto; margin-right:4px;"><% if (rating.short_label) { %><span style="color:#9c9086; font-weight:400; font-size:10px;">(<%= rating.short_label %>)&nbsp;</span><% } %><%= rating.score %><span style="color:#9c9086; font-weight:400;">/<%= rating.max_score %></span>
                                                        </span>
                                                    <% }) %>
                                                </div>
                                                <% } %>
                                            </td>
                                        </tr>
                                    </table>
                                    <% if (movie.comment) { %>
                                    <table width="100%" cellpadding="0" cellspacing="0" style="margin-top: 18px;">
                                        <tr>
                                            <td width="2" style="background-color:#c8a24a; font-size:0; line-height:0;">&nbsp;</td>
                                            <td style="padding: 2px 0 2px 14px;">
                                                <div style="font-family: Inter, -apple-system, 'Segoe UI', Helvetica, Arial, sans-serif; font-size:11px; font-weight:500; letter-spacing:1.5px; text-transform:uppercase; color:#c8a24a; margin-bottom: 4px;">
                                                    Note de la r&eacute;daction
                                                </div>
                                                <p style="margin:0; font-family:'Cormorant Garamond','Tiempos Headline',Georgia,'Times New Roman',serif; font-size:19px; line-height:1.4; color:#faf9f5; font-style:italic;">
                                                    <%= movie.comment %>
                                                </p>
                                            </td>
                                        </tr>
                                    </table>
                                    <% } %>
                                    <% if (movie.ui_showtimes.main_cinema) { %>
                                    <table width="100%" cellpadding="0" cellspacing="0" style="margin-top: 18px; background-color:#241d18; border-radius:8px;">
                                        <tr><td style="padding: 14px 16px;">
                                            <div style="font-family: Inter, -apple-system, 'Segoe UI', Helvetica, Arial, sans-serif; font-size:13px; line-height:1.5; color:#faf9f5;">
                                                <strong><%= text.ui_labels.where_to_see %></strong><br>
                                                <%= text.ui_labels.mainly_at %> <strong style="color:#c8a24a;"><%= movie.ui_showtimes.main_cinema %></strong>
                                                (<%= movie.ui_showtimes.main_count %> <%= text.ui_labels.screenings %>)
                                                <% if (movie.ui_showtimes.remainder_text) { %>
                                                    <br><span style="color:#9c9086; font-style:italic; font-size:12px;"><%= movie.ui_showtimes.remainder_text %></span>
                                                <% } %>
                                            </div>
                                            <div style="margin-top: 12px;">
                                                <a href="https://www.allocine.fr/film/fichefilm_gen_cfilm=<%= movie.id %>.html"
                                                   style="display:inline-block; background-color:#b5432c; color:#ffffff; text-decoration:none; font-family: Inter, -apple-system, 'Segoe UI', Helvetica, Arial, sans-serif; font-size:13px; font-weight:500; padding: 9px 16px; border-radius:8px;">
                                                    <%= text.ui_labels.see_all_showtimes %> &rarr;
                                                </a>
                                            </div>
                                        </td></tr>
                                    </table>
                                    <% } %>
                                </td></tr>
                            </table>
                        </td>
                    </tr>
                    <% } else { %>
                    <!-- ===== STANDARD MOVIE (cream) ===== -->
                    <tr>
                        <td style="padding: 20px 32px 4px 32px;">
                            <table width="100%" cellpadding="0" cellspacing="0" <% if (mIdx > 0 || sIdx === 0) { %>style="border-top:1px solid #ebe6df;"<% } %>>
                                <tr>
                                    <td width="130" valign="top" style="padding-top: 20px;">
                                        <img src="<%= movie.poster_url %>" width="120" alt="<%= movie.title %>" style="display:block; border-radius:8px; border:1px solid #e6dfd8;">
                                    </td>
                                    <td valign="top" style="padding: 20px 0 0 18px;">
                                        <% if (movie.is_new_release || movie.is_premiere) { %>
                                        <div style="margin-bottom: 6px;">
                                            <span style="display:inline-block; background-color:#b5432c; color:#ffffff; font-family: Inter, -apple-system, 'Segoe UI', Helvetica, Arial, sans-serif; font-size:10px; font-weight:500; letter-spacing:1.5px; text-transform:uppercase; padding: 3px 10px; border-radius:9999px;">
                                                <%= movie.is_premiere ? 'Avant-premi&egrave;re' : 'Sortie' %>
                                            </span>
                                        </div>
                                        <% } %>
                                        <h3 style="margin:0 0 5px 0; font-family:'Cormorant Garamond','Tiempos Headline',Georgia,'Times New Roman',serif; font-size:23px; font-weight:500; line-height:1.2; letter-spacing:-0.3px; color:#141413;">
                                            <%= movie.title %>
                                        </h3>
                                        <div style="font-family: Inter, -apple-system, 'Segoe UI', Helvetica, Arial, sans-serif; font-size:13px; line-height:1.5; color:#6c6a64; margin-bottom: 10px;">
                                            <%= movie.year %><% if (movie.duration_minutes) { %> &middot; <%= movie.duration_minutes %> min<% } %><% if (movie.genre) { %> &middot; <%= movie.genre %><% } %>
                                            <br>De <%= movie.director %>
                                        </div>

                                        <% if (movie.comment) { %>
                                        <table width="100%" cellpadding="0" cellspacing="0" style="margin: 0 0 12px 0;">
                                            <tr>
                                                <td width="2" style="background-color:#c8a24a; font-size:0; line-height:0;">&nbsp;</td>
                                                <td style="background-color:#f5f0e8; padding: 10px 14px; border-radius: 0 8px 8px 0;">
                                                    <p style="margin:0; font-family:'Cormorant Garamond','Tiempos Headline',Georgia,'Times New Roman',serif; font-size:17px; line-height:1.4; color:#252523; font-style:italic;">
                                                        <%= movie.comment %>
                                                    </p>
                                                </td>
                                            </tr>
                                        </table>
                                        <% } %>

                                        <!-- RATINGS -->
                                        <% if (movie.ui_ratings.length > 0) { %>
                                        <div style="margin-bottom: 4px;">
                                            <% movie.ui_ratings.forEach(rating => { %>
                                                <span style="display:inline-block; margin: 0 10px 6px 0; font-family: Inter, -apple-system, 'Segoe UI', Helvetica, Arial, sans-serif; font-size:12px; font-weight:500; color:#141413;">
                                                    <img src="<%= rating.logo_url %>" height="14" alt="<%= rating.source %>" style="vertical-align:middle; height:14px; width:auto; margin-right:4px;"><% if (rating.short_label) { %><span style="color:#8e8b82; font-weight:400; font-size:10px;">(<%= rating.short_label %>)&nbsp;</span><% } %><%= rating.score %><span style="color:#8e8b82; font-weight:400;">/<%= rating.max_score %></span>
                                                </span>
                                            <% }) %>
                                        </div>
                                        <% } %>

                                        <!-- SHOWTIMES -->
                                        <% if (movie.ui_showtimes.main_cinema) { %>
                                        <table width="100%" cellpadding="0" cellspacing="0" style="margin-top: 6px; background-color:#efe9de; border-radius:8px;">
                                            <tr><td style="padding: 12px 14px;">
                                                <div style="font-family: Inter, -apple-system, 'Segoe UI', Helvetica, Arial, sans-serif; font-size:13px; line-height:1.5; color:#252523;">
                                                    <strong><%= text.ui_labels.where_to_see %></strong><br>
                                                    <%= text.ui_labels.mainly_at %> <strong><%= movie.ui_showtimes.main_cinema %></strong>
                                                    (<%= movie.ui_showtimes.main_count %> <%= text.ui_labels.screenings %>)
                                                    <% if (movie.ui_showtimes.remainder_text) { %>
                                                        <br><span style="color:#6c6a64; font-style:italic; font-size:12px;"><%= movie.ui_showtimes.remainder_text %></span>
                                                    <% } %>
                                                </div>
                                                <div style="margin-top: 10px;">
                                                    <a href="https://www.allocine.fr/film/fichefilm_gen_cfilm=<%= movie.id %>.html"
                                                       style="display:inline-block; background-color:#b5432c; color:#ffffff; text-decoration:none; font-family: Inter, -apple-system, 'Segoe UI', Helvetica, Arial, sans-serif; font-size:13px; font-weight:500; padding: 8px 14px; border-radius:8px;">
                                                        <%= text.ui_labels.see_all_showtimes %> &rarr;
                                                    </a>
                                                </div>
                                            </td></tr>
                                        </table>
                                        <% } else { %>
                                        <div style="margin-top: 6px; font-family: Inter, -apple-system, 'Segoe UI', Helvetica, Arial, sans-serif; color:#8e8b82; font-size:12px; font-style:italic;">
                                            <%= text.ui_labels.no_showtimes %>
                                        </div>
                                        <% } %>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                    <% } %>
                    <% }) %>
                <% }) %>

                <!-- ===== CONCLUSION (brick callout) ===== -->
                <tr>
                    <td style="padding: 44px 24px 24px 24px;">
                        <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#b5432c; border-radius:12px;">
                            <tr><td align="center" style="padding: 36px 32px;">
                                <p style="margin:0; font-family:'Cormorant Garamond','Tiempos Headline',Georgia,'Times New Roman',serif; font-size:26px; font-weight:500; line-height:1.25; letter-spacing:-0.3px; color:#ffffff;">
                                    <%= text.global_conclusion %>
                                </p>
                            </td></tr>
                        </table>
                    </td>
                </tr>

                <!-- ===== FOOTER (espresso) ===== -->
                <tr>
                    <td align="center" style="background-color:#161210; padding: 32px;">
                        <div style="font-family:'Cormorant Garamond','Tiempos Headline',Georgia,'Times New Roman',serif; font-size:20px; font-weight:500; letter-spacing:-0.3px; color:#faf9f5;">
                            &#10035;&nbsp;<%= text.newsletter_title %>
                        </div>
                        <p style="margin: 8px 0 0 0; font-family: Inter, -apple-system, 'Segoe UI', Helvetica, Arial, sans-serif; font-size:13px; line-height:1.55; color:#9c9086;">
                            Le programme de la semaine dans les salles parisiennes, choisi &agrave; la main.
                        </p>
                    </td>
                </tr>
            </table>

        </td></tr>
    </table>
</body>
</html>
