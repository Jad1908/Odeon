# Resend configuration for sending the newsletter (copy to .env and fill in).
# API key: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Segment ("the base"; Resend's former "audiences") to send to
RESEND_SEGMENT_ID=00000000-0000-0000-0000-000000000000
# Sender address — the domain must be verified in Resend
RESEND_FROM=Paris Ciné <newsletter@yourdomain.com>
