# Resend configuration for sending the newsletter (copy to .env and fill in).
# API key: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Segment ("the base"; Resend's former "audiences") to send to
RESEND_SEGMENT_ID=00000000-0000-0000-0000-000000000000
# Sender address — the domain must be verified in Resend
RESEND_FROM=Paris Ciné <newsletter@yourdomain.com>

# Telegram watchlist bot — token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# Optional: where to store the subscriber list. Defaults to watchlist/subscribers.json.
# On an ephemeral host, point this at a persistent volume, e.g. /data/subscribers.json.
# SUBSCRIBERS_FILE=/data/subscribers.json
